};

// Aerospace-grade section breaks manager
const sectionBreaksManager = {
  breaks: [] as Array<{ id: string; type: string; position: number }>,

  insertBreak: (type: string) => {
    const breakItem = {
      id: `break-${Date.now()}`,
      type,
