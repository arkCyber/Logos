const insertShape = () => {
  if (!editor.value) return;
  
  const shapeType = prompt('请选择形状类型 (rectangle/circle/triangle/line/arrow):', 'rectangle');
  if (!shapeType) return;
  
  let shapeHtml = '';
  const width = 200;
  const height = 150;
  
  switch (shapeType.toLowerCase()) {
    case 'rectangle':
      shapeHtml = `<div style="width: ${width}px; height: ${height}px; border: 2px solid #000; background-color: #f0f0f0; display: inline-block;"></div>`;
      break;
    case 'circle':
      shapeHtml = `<div style="width: ${width}px; height: ${width}px; border: 2px solid #000; background-color: #f0f0f0; border-radius: 50%; display: inline-block;"></div>`;
      break;
    case 'triangle':
      shapeHtml = `<div style="width: 0; height: 0; border-left: ${width/2}px solid transparent; border-right: ${width/2}px solid transparent; border-bottom: ${height}px solid #000; display: inline-block;"></div>`;
      break;
    case 'line':
      shapeHtml = `<div style="width: ${width}px; height: 2px; background-color: #000; display: inline-block;"></div>`;
      break;
    case 'arrow':
      shapeHtml = `<div style="width: ${width}px; height: 2px; background-color: #000; display: inline-block; position: relative;">
        <div style="position: absolute; right: -10px; top: -4px; width: 0; height: 0; border-left: 10px solid #000; border-top: 5px solid transparent; border-bottom: 5px solid transparent;"></div>
      </div>`;
      break;
    default:
      aiError.value = '不支持的形状类型';
      setTimeout(() => (aiError.value = null), 2000);
      return;
  }
  
  editor.value.chain().focus().insertContent(shapeHtml).run();
};

const insertIcon = () => {
  if (!editor.value) return;
  
  const iconType = prompt('请选择图标类型 (star/heart/check/cross/arrow/flag/info/warning/error):', 'star');
  if (!iconType) return;
  
  const icons: Record<string, string> = {
    star: '⭐',
    heart: '❤️',
    check: '✅',
    cross: '❌',
    arrow: '➡️',
    flag: '🚩',
    info: 'ℹ️',
    warning: '⚠️',
    error: '🔴',
    success: '🟢',
    question: '❓',
    exclamation: '❗',
    bullet: '•',
    diamond: '◆',
    square: '■',
    circle: '●'
  };
  
  const icon = icons[iconType.toLowerCase()];
  if (icon) {
    editor.value.chain().focus().insertContent(`<span style="font-size: 24px;">${icon}</span>&nbsp;`).run();
  } else {
    aiError.value = '不支持的图标类型';
    setTimeout(() => (aiError.value = null), 2000);
  }
};

