const trackChanges = () => {
  if (!editor.value) return;
  
  // Toggle track changes mode
  trackChangesEnabled.value = !trackChangesEnabled.value;
  
  if (trackChangesEnabled.value) {
    // Enable track changes by adding a visual indicator
    editor.value.chain().focus().setMark('highlight', { color: '#ffff00' }).run();
    aiError.value = '修订模式已开启';
  } else {
    // Disable track changes
    editor.value.chain().focus().unsetMark('highlight').run();
    aiError.value = '修订模式已关闭';
  }
  
  setTimeout(() => (aiError.value = null), 2000);
};

