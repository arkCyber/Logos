const addImage = () => {
  const url = prompt('请输入图片 URL:');
  if (url) {
    // Insert as HTML since Image extension may not be available
    editor.value?.chain().focus().insertContent(`<img src="${url}" style="max-width: 100%;">`).run();
  }
