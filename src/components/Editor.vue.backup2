const insertPageNumber = () => {
  if (!editor.value) return;
  
  const position = prompt('请选择页码位置 (left/center/right):', 'center');
  if (!position) return;
  
  let alignStyle = '';
  switch (position.toLowerCase()) {
    case 'left':
      alignStyle = 'text-align: left;';
      break;
    case 'right':
      alignStyle = 'text-align: right;';
      break;
    case 'center':
    default:
      alignStyle = 'text-align: center;';
      break;
  }
  
  // Insert page number placeholder
  const pageNumberHtml = `<div style="${alignStyle} padding: 10px; border-top: 1px solid #ccc; margin-top: 20px; font-size: 14px; color: #666;">📄 页码: <span class="page-number">1</span></div>`;
  editor.value.chain().focus().insertContent(pageNumberHtml).run();
  
  aiError.value = '页码已插入';
  setTimeout(() => (aiError.value = null), 2000);
};

