    ErrorSeverity.ERROR,
    ErrorCategory.SYSTEM,
    { timestamp: Date.now(), additionalData: { originalError: err, componentInfo: info } }
  );
  logger.error('Component error captured', appError, LogCategory.SYSTEM);
  return false;
});

