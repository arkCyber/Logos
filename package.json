{
  "name": "logos",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src --ext .ts,.vue --ignore-path .gitignore",
    "lint:fix": "eslint src --ext .ts,.vue --fix --ignore-path .gitignore",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\"",
    "type-check": "vue-tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite",
    "audit": "bun run lint && bun run type-check && bun run test:run"
  },
  "dependencies": {
