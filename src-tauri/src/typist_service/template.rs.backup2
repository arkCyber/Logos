    #[test]
    fn test_render_template_special_characters() {
        let mut engine = TemplateEngine::new();
        let template = Template {
            name: "test".to_string(),
            description: "Test template".to_string(),
            content: "Special: {{text}}".to_string(),
            variables: vec![],
            metadata: TemplateMetadata {
                category: TemplateCategory::Custom,
                author: None,
                version: None,
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
            },
        };
        engine.register_template(template);
        
        let mut values = HashMap::new();
        values.insert("text".to_string(), "<script>alert('xss')</script>".to_string());
        
        let result = engine.render("test", &values);
        assert!(result.is_ok());
        // Should not escape - template engine doesn't do HTML escaping
        assert!(result.unwrap().contains("<script>"));
    }

