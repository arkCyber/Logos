    #[test]
    fn test_render_template_nested_braces() {
        let mut engine = TemplateEngine::new();
        let template = Template {
            name: "test".to_string(),
            description: "Test template".to_string(),
            content: "{{{{x}}}}".to_string(),
            variables: vec![],
            metadata: TemplateMetadata {
                category: TemplateCategory::Custom,
                author: None,
                version: None,
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
            },
        };
        engine.register_template(template);
        
        let mut values = HashMap::new();
        values.insert("x".to_string(), "value".to_string());
        
        let result = engine.render("test", &values);
        assert!(result.is_ok());
        // Should replace the inner {{x}} first, then the outer
        assert!(result.unwrap().contains("value"));
    }

