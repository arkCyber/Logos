    #[test]
    fn test_render_template_multiple_variables() {
        let mut engine = TemplateEngine::new();
        let template = Template {
            name: "test".to_string(),
            description: "Test template".to_string(),
            content: "Hello {{name}}, you are {{age}} years old".to_string(),
            variables: vec![],
            metadata: TemplateMetadata {
                category: TemplateCategory::Custom,
                author: None,
                version: None,
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
            },
        };
        engine.register_template(template);
        
        let mut values = HashMap::new();
        values.insert("name".to_string(), "Alice".to_string());
        values.insert("age".to_string(), "30".to_string());
        
        let result = engine.render("test", &values);
        assert!(result.is_ok());
        assert_eq!(result.unwrap(), "Hello Alice, you are 30 years old");
    }

    #[test]
    fn test_render_template_partial_substitution() {
        let mut engine = TemplateEngine::new();
        let template = Template {
            name: "test".to_string(),
            description: "Test template".to_string(),
            content: "Hello {{name}}, {{greeting}}".to_string(),
            variables: vec![
                TemplateVariable {
                    name: "greeting".to_string(),
                    default_value: Some("Welcome".to_string()),
                    description: None,
                    required: false,
                },
            ],
        };
        engine.register_template(template);
        
        let mut values = HashMap::new();
        values.insert("name".to_string(), "Bob".to_string());
        
        let result = engine.render("test", &values);
        assert!(result.is_ok());
        assert_eq!(result.unwrap(), "Hello Bob, Welcome");
    }

