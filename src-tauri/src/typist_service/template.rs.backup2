    #[test]
    fn test_render_template_override_default() {
        let mut engine = TemplateEngine::new();
        let template = Template {
            name: "test".to_string(),
            description: "Test template".to_string(),
            content: "Hello {{name}}".to_string(),
            variables: vec![
                TemplateVariable {
                    name: "name".to_string(),
                    default_value: Some("Default".to_string()),
                    description: None,
                    required: false,
                },
            ],
        };
        engine.register_template(template);
        
        let mut values = HashMap::new();
        values.insert("name".to_string(), "Custom".to_string());
        
        let result = engine.render("test", &values);
        assert!(result.is_ok());
        assert_eq!(result.unwrap(), "Hello Custom");
    }

