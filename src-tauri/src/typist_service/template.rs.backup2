    #[test]
    fn test_extract_variables_from_content() {
        let content = "Hello {{name}}, {{greeting}}";
        let variables = TemplateEngine::extract_variables_from_content(content);
        assert_eq!(variables.len(), 2);
        assert!(variables.iter().any(|v| v.name == "name"));
        assert!(variables.iter().any(|v| v.name == "greeting"));
    }

    #[test]
    fn test_extract_variables_no_duplicates() {
        let content = "{{x}} and {{x}} again";
        let variables = TemplateEngine::extract_variables_from_content(content);
        assert_eq!(variables.len(), 1);
        assert_eq!(variables[0].name, "x");
    }

    #[test]
    fn test_extract_variables_empty() {
        let content = "No variables here";
        let variables = TemplateEngine::extract_variables_from_content(content);
        assert!(variables.is_empty());
    }

    #[test]
    fn test_extract_variables_single_brace() {
        let content = "{single} brace";
        let variables = TemplateEngine::extract_variables_from_content(content);
        assert!(variables.is_empty());
    }

    #[test]
    fn test_extract_variables_nested() {
        let content = "{{{{x}}}}";
        let variables = TemplateEngine::extract_variables_from_content(content);
        // The implementation extracts the first complete {{...}} pattern
        // For nested braces, it extracts the outer pattern's content
        assert!(!variables.is_empty());
    }

    #[test]
    fn test_load_save_template_roundtrip() {
        let mut engine = TemplateEngine::new();
        let template = Template {
            name: "test".to_string(),
            description: "Test template".to_string(),
            content: "Hello {{name}}".to_string(),
            variables: vec![],
            metadata: TemplateMetadata {
                category: TemplateCategory::Custom,
                author: None,
                version: None,
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
            },
        };
        engine.register_template(template);

        let dir = PathBuf::from("/tmp/test_typist_templates");
        let save_result = engine.save_template_to_file("test", &dir);
        assert!(save_result.is_ok());

        let mut engine2 = TemplateEngine::new();
        let load_result = engine2.load_template_from_file(&save_result.unwrap());
        assert!(load_result.is_ok());
        assert_eq!(load_result.unwrap(), "test");

        // Clean up
        let _ = std::fs::remove_dir_all(dir);
    }
}
