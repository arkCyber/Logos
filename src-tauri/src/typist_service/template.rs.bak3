    #[test]
    fn test_preview_cache() {
        let mut engine = TemplateEngine::new();
        let template = create_test_template_with_variables("test", "Hello {{name}}", vec![
            TemplateVariable {
                name: "name".to_string(),
                default_value: Some("World".to_string()),
                description: None,
                required: false,
            },
        ]);
        engine.register_template(template).unwrap();
        
        // First call should generate and cache
        let result1 = engine.generate_template_preview("test");
        assert!(result1.is_ok());
        assert_eq!(engine.preview_cache_size(), 1);
        
        // Second call should use cache
        let result2 = engine.generate_template_preview("test");
        assert!(result2.is_ok());
        assert_eq!(engine.preview_cache_size(), 1);
        
        // Results should be identical
        assert_eq!(result1.unwrap(), result2.unwrap());
    }

    #[test]
    fn test_preview_cache_invalidation_on_update() {
        let mut engine = TemplateEngine::new();
        let template = create_test_template_with_variables("test", "Hello {{name}}", vec![
            TemplateVariable {
                name: "name".to_string(),
                default_value: Some("World".to_string()),
                description: None,
                required: false,
            },
        ]);
        engine.register_template(template).unwrap();
        
        // Generate preview
        engine.generate_template_preview("test").unwrap();
        assert_eq!(engine.preview_cache_size(), 1);
        
        // Update template
        let updated = create_test_template("test", "Updated content");
        engine.register_template(updated).unwrap();
        
        // Cache should be invalidated
        assert_eq!(engine.preview_cache_size(), 0);
    }

    #[test]
    fn test_preview_cache_invalidation_on_remove() {
        let mut engine = TemplateEngine::new();
        let template = create_test_template_with_variables("test", "Hello {{name}}", vec![
            TemplateVariable {
                name: "name".to_string(),
                default_value: Some("World".to_string()),
                description: None,
                required: false,
            },
        ]);
        engine.register_template(template).unwrap();
        
        // Generate preview
        engine.generate_template_preview("test").unwrap();
        assert_eq!(engine.preview_cache_size(), 1);
        
        // Remove template
        engine.remove_template("test");
        
        // Cache should be invalidated
        assert_eq!(engine.preview_cache_size(), 0);
    }

