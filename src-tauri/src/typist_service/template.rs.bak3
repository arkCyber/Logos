use std::collections::HashMap;
use std::path::PathBuf;
use std::sync::Arc;
use serde::{Deserialize, Serialize};
use chrono::{DateTime, Utc};
use sha2::{Sha256, Digest};
use crate::typist_service::{TypstCompiler, TypstRenderer};

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct TemplateVariable {
    pub name: String,
    pub default_value: Option<String>,
    pub description: Option<String>,
    pub required: bool,
}

#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
pub enum TemplateCategory {
    Academic,
    Business,
    Technical,
    Creative,
    Presentation,
    Custom,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct TemplateMetadata {
    pub category: TemplateCategory,
    pub author: Option<String>,
    pub version: Option<String>,
    pub created_at: DateTime<Utc>,
    pub updated_at: DateTime<Utc>,
    pub thumbnail: Option<String>, // Base64 encoded or file path
    pub previous_versions: Vec<TemplateVersionHistory>, // Version history
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct TemplateVersionHistory {
    pub version: String,
    pub updated_at: DateTime<Utc>,
    pub content_hash: String, // SHA-256 hash of content
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Template {
    pub name: String,
    pub description: String,
    pub content: String,
    pub variables: Vec<TemplateVariable>,
    pub metadata: TemplateMetadata,
}

#[derive(Debug, Clone)]
pub struct TemplateEngine {
    templates: HashMap<String, Template>,
    preview_cache: HashMap<String, Arc<Vec<u8>>>,
}

impl TemplateEngine {
    pub fn new() -> Self {
        Self {
            templates: HashMap::new(),
            preview_cache: HashMap::new(),
        }
    }

    /// Register a template
    pub fn register_template(&mut self, template: Template) -> Result<(), String> {
        // Validate template name
        if template.name.is_empty() {
            return Err("Template name cannot be empty".to_string());
        }
        
        // Validate template name format (alphanumeric, hyphens, underscores)
        if !template.name.chars().all(|c| c.is_alphanumeric() || c == '-' || c == '_') {
            return Err("Template name can only contain alphanumeric characters, hyphens, and underscores".to_string());
        }
        
        // Validate template content is not empty
        if template.content.trim().is_empty() {
            return Err("Template content cannot be empty".to_string());
        }
        
        // Calculate content hash
        let content_hash = Self::calculate_content_hash(&template.content);
        let template_name = template.name.clone();
        
        // Check if template already exists and track version history
        if let Some(existing) = self.templates.get(&template_name) {
            let mut metadata = template.metadata.clone();
            
            // Add current version to history if content changed
            if existing.metadata.version != template.metadata.version || 
               Self::calculate_content_hash(&existing.content) != content_hash {
                if let Some(ref version) = existing.metadata.version {
                    metadata.previous_versions.push(TemplateVersionHistory {
                        version: version.clone(),
                        updated_at: existing.metadata.updated_at,
                        content_hash: Self::calculate_content_hash(&existing.content),
                    });
                }
            }
            
            let updated_template = Template {
                metadata,
                ..template
            };
            
            // Invalidate preview cache when template is updated
            self.preview_cache.remove(&template_name);
            
            self.templates.insert(template_name, updated_template);
        } else {
            // New template
            let mut metadata = template.metadata.clone();
            if metadata.previous_versions.is_empty() {
                metadata.previous_versions = Vec::new();
            }
            
            let new_template = Template {
                metadata,
                ..template
            };
            
            self.templates.insert(template_name, new_template);
        }
        
        Ok(())
    }

    /// Calculate SHA-256 hash of content
    fn calculate_content_hash(content: &str) -> String {
        let mut hasher = Sha256::new();
        hasher.update(content.as_bytes());
        format!("{:x}", hasher.finalize())
    }

    /// Get a template by name
    pub fn get_template(&self, name: &str) -> Option<&Template> {
        self.templates.get(name)
    }

    /// Remove a template
    pub fn remove_template(&mut self, name: &str) -> bool {
        self.preview_cache.remove(name);
        self.templates.remove(name).is_some()
    }

    /// List all template names
    pub fn list_templates(&self) -> Vec<String> {
        self.templates.keys().cloned().collect()
    }

    /// Get all templates
    pub fn get_all_templates(&self) -> Vec<Template> {
        self.templates.values().cloned().collect()
    }

    /// Get templates by category
    pub fn get_templates_by_category(&self, category: TemplateCategory) -> Vec<Template> {
        self.templates
            .values()
            .filter(|t| t.metadata.category == category)
            .cloned()
            .collect()
    }

    /// Search templates by name or description
    pub fn search_templates(&self, query: &str) -> Vec<Template> {
        let lower_query = query.to_lowercase();
        self.templates
            .values()
            .filter(|t| {
                t.name.to_lowercase().contains(&lower_query)
                    || t.description.to_lowercase().contains(&lower_query)
            })
            .cloned()
            .collect()
    }

    /// Load all templates from a directory
    pub fn load_templates_from_directory(&mut self, dir: &PathBuf) -> Result<usize, String> {
        if !dir.exists() {
            return Err(format!("Template directory does not exist: {}", dir.display()));
        }

        if !dir.is_dir() {
            return Err(format!("Path is not a directory: {}", dir.display()));
        }

        let mut count = 0;
        let entries = std::fs::read_dir(dir)
            .map_err(|e| format!("Failed to read directory: {}", e))?;

        for entry in entries {
            let entry = entry.map_err(|e| format!("Failed to read entry: {}", e))?;
            let path = entry.path();

            if path.extension().map_or(false, |ext| ext == "typ") {
                if let Some(file_name) = path.file_stem() {
                    let name = file_name.to_string_lossy().to_string();
                    let content = std::fs::read_to_string(&path)
                        .map_err(|e| format!("Failed to read file {}: {}", path.display(), e))?;

                    let template = Template {
                        name: name.clone(),
                        description: format!("Template loaded from {}", path.display()),
                        content: content.clone(),
                        variables: Self::extract_variables_from_content(&content),
                        metadata: TemplateMetadata {
                            category: TemplateCategory::Custom,
                            author: None,
                            version: None,
                            created_at: Utc::now(),
                            updated_at: Utc::now(),
                            thumbnail: None,
                previous_versions: Vec::new(),
                        },
                    };

                    self.register_template(template)?;
                    count += 1;
                }
            }
        }

        Ok(count)
    }

    /// Extract variable placeholders from template content
    fn extract_variables_from_content(content: &str) -> Vec<TemplateVariable> {
        let mut variables = Vec::new();
        let mut seen = std::collections::HashSet::new();

        // Find all {{variable}} patterns
        let mut chars = content.chars().peekable();
        while let Some(ch) = chars.next() {
            if ch == '{' {
                if let Some(&'{') = chars.peek() {
                    chars.next(); // consume second '{'
                    
                    // Extract variable name
                    let mut var_name = String::new();
                    while let Some(&c) = chars.peek() {
                        if c == '}' {
                            chars.next(); // consume first '}'
                            if let Some(&'}') = chars.peek() {
                                chars.next(); // consume second '}'
                                if !var_name.is_empty() && !seen.contains(&var_name) {
                                    seen.insert(var_name.clone());
                                    variables.push(TemplateVariable {
                                        name: var_name.clone(),
                                        default_value: None,
                                        description: None,
                                        required: false,
                                    });
                                }
                                break;
                            }
                        }
                        var_name.push(c);
                        chars.next();
                    }
                }
            }
        }

        variables
    }

    /// Load a single template from a file
    pub fn load_template_from_file(&mut self, path: &PathBuf) -> Result<String, String> {
        if !path.exists() {
            return Err(format!("Template file does not exist: {}", path.display()));
        }

        let file_name = path.file_stem()
            .ok_or_else(|| format!("Invalid file name: {}", path.display()))?
            .to_string_lossy()
            .to_string();

        let content = std::fs::read_to_string(path)
            .map_err(|e| format!("Failed to read file {}: {}", path.display(), e))?;

        let template = Template {
            name: file_name.clone(),
            description: format!("Template loaded from {}", path.display()),
            content: content.clone(),
            variables: Self::extract_variables_from_content(&content),
            metadata: TemplateMetadata {
                category: TemplateCategory::Custom,
                author: None,
                version: None,
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
                previous_versions: Vec::new(),
            },
        };

        self.register_template(template)?;
        Ok(file_name)
    }

    /// Save a template to a file
    pub fn save_template_to_file(&self, template_name: &str, dir: &PathBuf) -> Result<PathBuf, String> {
        let template = self.get_template(template_name)
            .ok_or_else(|| format!("Template '{}' not found", template_name))?;

        if !dir.exists() {
            std::fs::create_dir_all(dir)
                .map_err(|e| format!("Failed to create directory: {}", e))?;
        }

        let file_path = dir.join(format!("{}.typ", template_name));
        std::fs::write(&file_path, &template.content)
            .map_err(|e| format!("Failed to write file: {}", e))?;

        Ok(file_path)
    }

    /// Render a template with variable values
    pub fn render(&self, template_name: &str, values: &HashMap<String, String>) -> Result<String, String> {
        let template = self.templates.get(template_name)
            .ok_or_else(|| format!("Template '{}' not found", template_name))?;

        // Check required variables
        for var in &template.variables {
            if var.required && !values.contains_key(&var.name) {
                return Err(format!("Required variable '{}' not provided", var.name));
            }
        }

        // Replace variables in content
        let mut content = template.content.clone();
        for (key, value) in values {
            let placeholder = format!("{{{{{}}}}}", key);
            content = content.replace(&placeholder, value);
        }

        // Replace remaining variables with defaults
        for var in &template.variables {
            if !values.contains_key(&var.name) {
                if let Some(default) = &var.default_value {
                    let placeholder = format!("{{{{{}}}}}", var.name);
                    content = content.replace(&placeholder, default);
                }
            }
        }

        Ok(content)
    }

    /// Validate template syntax
    pub fn validate_template(&self, template_name: &str) -> Result<(), String> {
        let template = self.templates.get(template_name)
            .ok_or_else(|| format!("Template '{}' not found", template_name))?;

        // Check for unclosed variable placeholders
        let mut open_count = 0;
        for ch in template.content.chars() {
            if ch == '{' {
                open_count += 1;
            } else if ch == '}' {
                open_count -= 1;
            }
        }

        if open_count != 0 {
            return Err("Template has unclosed variable placeholders".to_string());
        }

        Ok(())
    }

    /// Create a basic slide template
    pub fn create_slide_template(title: &str) -> Template {
        Template {
            name: title.to_string(),
            description: "Basic slide template".to_string(),
            content: r#"= {{title}}

{{content}}
"#.to_string(),
            variables: vec![
                TemplateVariable {
                    name: "title".to_string(),
                    default_value: Some("Slide Title".to_string()),
                    description: Some("The title of the slide".to_string()),
                    required: false,
                },
                TemplateVariable {
                    name: "content".to_string(),
                    default_value: Some("Slide content goes here".to_string()),
                    description: Some("The content of the slide".to_string()),
                    required: false,
                },
            ],
            metadata: TemplateMetadata {
                category: TemplateCategory::Presentation,
                author: Some("LOGOS".to_string()),
                version: Some("1.0.0".to_string()),
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
                previous_versions: Vec::new(),
            },
        }
    }

