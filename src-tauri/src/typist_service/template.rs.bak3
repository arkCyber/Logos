    /// Create a creative writing template
    pub fn create_creative_writing_template(title: &str) -> Template {
        Template {
            name: title.to_string(),
            description: "Creative writing template for novels, stories, and scripts".to_string(),
            content: r#"#set page(
  paper: "a4",
  margin: (x: 2.5cm, y: 2.5cm)
)

#set text(
  font: "Georgia",
  size: 12pt,
  lang: "zh"
)

