  justify: true,
  leading: 1.6em,
  spacing: 0.8em
)

= {{title}}

== 第一章

{{chapter1}}

== 第二章

{{chapter2}}

== 第三章

{{chapter3}}
"#.to_string(),
            variables: vec![
                TemplateVariable {
                    name: "title".to_string(),
                    default_value: Some("作品标题".to_string()),
                    description: Some("作品标题".to_string()),
                    required: true,
