        let mut engine = TemplateEngine::new();
        let template = create_test_template("test", "Content");
        engine.register_template(template).unwrap();
        
        let temp_dir = std::env::temp_dir().join("typist_test_save");
        let result = engine.save_template_to_file("test", &temp_dir);
        assert!(result.is_ok());
        
