        let mut engine = TemplateEngine::new();
        let template = create_test_template("test", "Hello {{name}}");
        engine.register_template(template).unwrap();
        assert!(engine.remove_template("test"));
        assert!(!engine.list_templates().contains(&"test".to_string()));
