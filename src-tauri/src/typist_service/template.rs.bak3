    #[test]
    fn test_get_templates_by_category() {
        let mut engine = TemplateEngine::new();
        
        let academic = create_test_template("academic", "Academic content");
        let mut academic_with_meta = academic.clone();
        academic_with_meta.metadata.category = TemplateCategory::Academic;
        engine.register_template(academic_with_meta);
        
        let business = create_test_template("business", "Business content");
        let mut business_with_meta = business.clone();
        business_with_meta.metadata.category = TemplateCategory::Business;
        engine.register_template(business_with_meta);
        
        let academic_templates = engine.get_templates_by_category(TemplateCategory::Academic);
        assert_eq!(academic_templates.len(), 1);
        assert_eq!(academic_templates[0].name, "academic");
        
        let business_templates = engine.get_templates_by_category(TemplateCategory::Business);
        assert_eq!(business_templates.len(), 1);
        assert_eq!(business_templates[0].name, "business");
    }

    #[test]
    fn test_search_templates() {
        let mut engine = TemplateEngine::new();
        
        let template1 = create_test_template("test-template", "Content");
        let mut template1_with_desc = template1.clone();
        template1_with_desc.description = "Test description".to_string();
        engine.register_template(template1_with_desc);
        
        let template2 = create_test_template("other-template", "Content");
        let mut template2_with_desc = template2.clone();
        template2_with_desc.description = "Other content".to_string();
        engine.register_template(template2_with_desc);
        
        let results = engine.search_templates("test");
        assert!(results.len() >= 1); // May match both name and description
        assert!(results.iter().any(|t| t.name == "test-template"));
        
        let results = engine.search_templates("description");
        assert_eq!(results.len(), 1);
        assert_eq!(results[0].name, "test-template");
        
        let results = engine.search_templates("other");
        assert_eq!(results.len(), 1);
        assert_eq!(results[0].name, "other-template");
        
        let results = engine.search_templates("nonexistent");
        assert_eq!(results.len(), 0);
    }

