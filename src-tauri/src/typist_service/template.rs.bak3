                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
                previous_versions: Vec::new(),
            },
        }
    }

    /// Initialize default templates
    pub fn initialize_default_templates(&mut self) -> Result<(), String> {
        self.register_template(Self::create_slide_template("slide"))?;
        self.register_template(Self::create_document_template("document"))?;
        self.register_template(Self::create_code_template("code"))?;
        self.register_template(Self::create_academic_paper_template("academic-paper"))?;
        self.register_template(Self::create_technical_doc_template("technical-doc"))?;
        self.register_template(Self::create_business_report_template("business-report"))?;
        self.register_template(Self::create_resume_template("resume"))?;
        self.register_template(Self::create_creative_writing_template("creative-writing"))?;
        self.register_template(Self::create_lab_report_template("lab-report"))?;
        Ok(())
    }

    /// Generate a preview image for a template
    pub fn generate_template_preview(&mut self, template_name: &str) -> Result<Vec<u8>, String> {
        // Check cache first
        if let Some(cached) = self.preview_cache.get(template_name) {
            return Ok(cached.as_ref().clone());
        }

        let template = self.get_template(template_name)
            .ok_or_else(|| format!("Template '{}' not found", template_name))?;

        // Render the template with default values
        let mut values = HashMap::new();
        for var in &template.variables {
            if let Some(default) = &var.default_value {
                values.insert(var.name.clone(), default.clone());
            } else if !var.required {
                // Use empty string for optional variables without defaults
                values.insert(var.name.clone(), String::new());
            }
        }

        let rendered = self.render(template_name, &values)?;
        
        // Validate rendered content is not empty
        if rendered.trim().is_empty() {
            return Err("Rendered template content is empty".to_string());
        }
        
        // Compile and render to PNG
        let compiler = TypstCompiler::new();
        let document = compiler.compile(rendered)
            .map_err(|e| format!("Failed to compile template: {}", e))?;

        let renderer = TypstRenderer::render_first_page_to_png(&document, 144.0)
            .map_err(|e| format!("Failed to render preview: {}", e))?;

        // Cache the result
        let cached = Arc::new(renderer.clone());
        self.preview_cache.insert(template_name.to_string(), cached);

        Ok(renderer)
    }

    /// Update template metadata
    pub fn update_template_metadata(&mut self, template_name: &str, updates: TemplateMetadataUpdate) -> Result<(), String> {
        let template = self.templates.get_mut(template_name)
            .ok_or_else(|| format!("Template '{}' not found", template_name))?;

        if let Some(category) = updates.category {
            template.metadata.category = category;
        }
        if let Some(author) = updates.author {
            template.metadata.author = Some(author);
        }
        if let Some(version) = updates.version {
            template.metadata.version = Some(version);
        }
        if let Some(thumbnail) = updates.thumbnail {
            template.metadata.thumbnail = Some(thumbnail);
        }
        template.metadata.updated_at = Utc::now();

        // Invalidate preview cache when metadata is updated
        self.preview_cache.remove(template_name);

        Ok(())
    }

    /// Clear preview cache
    pub fn clear_preview_cache(&mut self) {
        self.preview_cache.clear();
    }

    /// Get preview cache size
    pub fn preview_cache_size(&self) -> usize {
        self.preview_cache.len()
    }
}

#[derive(Debug, Clone, Default, Serialize, Deserialize)]
pub struct TemplateMetadataUpdate {
    pub category: Option<TemplateCategory>,
    pub author: Option<String>,
    pub version: Option<String>,
    pub thumbnail: Option<String>,
}

impl Default for TemplateEngine {
    fn default() -> Self {
        Self::new()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    fn create_test_template(name: &str, content: &str) -> Template {
        Template {
            name: name.to_string(),
            description: "Test template".to_string(),
            content: content.to_string(),
            variables: vec![],
            metadata: TemplateMetadata {
                category: TemplateCategory::Custom,
                author: None,
                version: None,
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
                previous_versions: Vec::new(),
                previous_versions: Vec::new(),
            },
        }
    }

    fn create_test_template_with_variables(name: &str, content: &str, variables: Vec<TemplateVariable>) -> Template {
        Template {
            name: name.to_string(),
            description: "Test template".to_string(),
            content: content.to_string(),
            variables,
            metadata: TemplateMetadata {
                category: TemplateCategory::Custom,
                author: None,
                version: None,
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
                previous_versions: Vec::new(),
                previous_versions: Vec::new(),
            },
        }
    }

    #[test]
    fn test_template_engine_creation() {
        let engine = TemplateEngine::new();
        assert!(engine.list_templates().is_empty());
    }

    #[test]
    fn test_template_engine_default() {
        let engine = TemplateEngine::default();
        assert!(engine.list_templates().is_empty());
    }

    #[test]
    fn test_register_template() {
        let mut engine = TemplateEngine::new();
        let template = create_test_template("test", "Hello {{name}}");
        assert!(engine.register_template(template).is_ok());
        assert!(engine.list_templates().contains(&"test".to_string()));
    }

    #[test]
