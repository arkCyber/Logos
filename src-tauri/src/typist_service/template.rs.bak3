    #[test]
    fn test_update_template_metadata() {
        let mut engine = TemplateEngine::new();
        let template = create_test_template("test", "Content");
        engine.register_template(template).unwrap();
        
        let updates = TemplateMetadataUpdate {
            category: Some(TemplateCategory::Business),
            author: Some("New Author".to_string()),
            version: Some("2.0.0".to_string()),
            thumbnail: Some("new-thumbnail.png".to_string()),
        };
        
        let result = engine.update_template_metadata("test", updates);
        assert!(result.is_ok());
        
        let updated = engine.get_template("test").unwrap();
        assert_eq!(updated.metadata.category, TemplateCategory::Business);
        assert_eq!(updated.metadata.author, Some("New Author".to_string()));
        assert_eq!(updated.metadata.version, Some("2.0.0".to_string()));
        assert_eq!(updated.metadata.thumbnail, Some("new-thumbnail.png".to_string()));
    }

