                TemplateVariable {
                    name: "chapter3".to_string(),
                    default_value: Some("在此处输入第三章内容...".to_string()),
                    description: Some("第三章内容".to_string()),
                    required: false,
                },
            ],
            metadata: TemplateMetadata {
                category: TemplateCategory::Creative,
                author: Some("LOGOS".to_string()),
                version: Some("1.0.0".to_string()),
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
                previous_versions: Vec::new(),
            },
        }
    }

    /// Create a lab report template
    pub fn create_lab_report_template(title: &str) -> Template {
        Template {
            name: title.to_string(),
            description: "Laboratory report template with experiment methods and results".to_string(),
            content: r#"#set page(
  paper: "a4",
  margin: (x: 2cm, y: 2.5cm)
)

#set text(
