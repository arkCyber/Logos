    #[test]
    fn test_version_tracking_update_with_version_change() {
        let mut engine = TemplateEngine::new();
        
        // Register initial version
        let template1 = Template {
            name: "test".to_string(),
            description: "Test".to_string(),
            content: "Content v1".to_string(),
            variables: vec![],
            metadata: TemplateMetadata {
                category: TemplateCategory::Custom,
                author: None,
                version: Some("1.0.0".to_string()),
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
                previous_versions: Vec::new(),
            },
        };
        engine.register_template(template1).unwrap();
        
        // Update with new version
        let template2 = Template {
            name: "test".to_string(),
            description: "Test".to_string(),
            content: "Content v2".to_string(),
            variables: vec![],
            metadata: TemplateMetadata {
                category: TemplateCategory::Custom,
                author: None,
                version: Some("2.0.0".to_string()),
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
                previous_versions: Vec::new(),
            },
        };
        engine.register_template(template2).unwrap();
        
        let updated = engine.get_template("test").unwrap();
        assert_eq!(updated.metadata.version, Some("2.0.0".to_string()));
        assert_eq!(updated.metadata.previous_versions.len(), 1);
        assert_eq!(updated.metadata.previous_versions[0].version, "1.0.0");
    }

    #[test]
    fn test_version_tracking_update_with_content_change() {
        let mut engine = TemplateEngine::new();
        
        // Register initial version
        let template1 = Template {
            name: "test".to_string(),
            description: "Test".to_string(),
            content: "Content v1".to_string(),
            variables: vec![],
            metadata: TemplateMetadata {
                category: TemplateCategory::Custom,
                author: None,
                version: Some("1.0.0".to_string()),
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
                previous_versions: Vec::new(),
            },
        };
        engine.register_template(template1).unwrap();
        
        // Update with same version but different content
        let template2 = Template {
            name: "test".to_string(),
            description: "Test".to_string(),
            content: "Content v2".to_string(),
            variables: vec![],
            metadata: TemplateMetadata {
                category: TemplateCategory::Custom,
                author: None,
                version: Some("1.0.0".to_string()),
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
                previous_versions: Vec::new(),
            },
        };
        engine.register_template(template2).unwrap();
        
        let updated = engine.get_template("test").unwrap();
        assert_eq!(updated.metadata.version, Some("1.0.0".to_string()));
        assert_eq!(updated.metadata.previous_versions.len(), 1);
    }

    #[test]
    fn test_content_hash_consistency() {
        let content = "Test content";
        let hash1 = TemplateEngine::calculate_content_hash(content);
        let hash2 = TemplateEngine::calculate_content_hash(content);
        assert_eq!(hash1, hash2);
    }

    #[test]
    fn test_content_hash_uniqueness() {
        let hash1 = TemplateEngine::calculate_content_hash("Content 1");
        let hash2 = TemplateEngine::calculate_content_hash("Content 2");
        assert_ne!(hash1, hash2);
    }

    #[test]
    fn test_load_template_from_file_not_exists() {
        let mut engine = TemplateEngine::new();
        let path = PathBuf::from("/nonexistent/file.typ");
        let result = engine.load_template_from_file(&path);
        assert!(result.is_err());
        assert!(result.unwrap_err().contains("does not exist"));
    }

    #[test]
    fn test_extract_variables_from_content() {
        let content = "Hello {{name}}, {{greeting}}";
        let variables = TemplateEngine::extract_variables_from_content(content);
        assert_eq!(variables.len(), 2);
        assert!(variables.iter().any(|v| v.name == "name"));
        assert!(variables.iter().any(|v| v.name == "greeting"));
    }

    #[test]
    fn test_extract_variables_no_duplicates() {
        let content = "{{x}} and {{x}} again";
        let variables = TemplateEngine::extract_variables_from_content(content);
        assert_eq!(variables.len(), 1);
        assert_eq!(variables[0].name, "x");
    }

    #[test]
    fn test_extract_variables_empty() {
        let content = "No variables here";
        let variables = TemplateEngine::extract_variables_from_content(content);
        assert!(variables.is_empty());
    }

    #[test]
    fn test_extract_variables_single_brace() {
        let content = "{single} brace";
        let variables = TemplateEngine::extract_variables_from_content(content);
        assert!(variables.is_empty());
    }

    #[test]
    fn test_extract_variables_nested() {
        let content = "{{{{x}}}}";
        let variables = TemplateEngine::extract_variables_from_content(content);
        // The implementation extracts the first complete {{...}} pattern
        // For nested braces, it extracts the outer pattern's content
        assert!(!variables.is_empty());
    }

    #[test]
    fn test_load_save_template_roundtrip() {
        let mut engine = TemplateEngine::new();
        let template = Template {
            name: "test".to_string(),
            description: "Test template".to_string(),
            content: "Hello {{name}}".to_string(),
            variables: vec![],
            metadata: TemplateMetadata {
                category: TemplateCategory::Custom,
                author: None,
                version: None,
                created_at: Utc::now(),
                updated_at: Utc::now(),
                thumbnail: None,
                previous_versions: Vec::new(),
            },
        };
        engine.register_template(template).unwrap();

        let dir = PathBuf::from("/tmp/test_typist_templates");
        let save_result = engine.save_template_to_file("test", &dir);
        assert!(save_result.is_ok());

        let mut engine2 = TemplateEngine::new();
        let load_result = engine2.load_template_from_file(&save_result.unwrap());
        assert!(load_result.is_ok());
        assert_eq!(load_result.unwrap(), "test");

        // Clean up
        let _ = std::fs::remove_dir_all(dir);
    }
}
