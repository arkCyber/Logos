        let template_names: Vec<String> = templates.iter().map(|t| t.name.clone()).collect();
        assert!(template_names.contains(&"slide".to_string()));
        assert!(template_names.contains(&"document".to_string()));
        assert!(template_names.contains(&"code".to_string()));
    }

